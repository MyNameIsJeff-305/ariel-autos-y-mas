---
import "../styles/global.css";
import Header from "../components/layout/Header.astro";
import Footer from "../components/layout/Footer.astro";

export interface Props {
  title?: string;
  description?: string;
  image?: string;
  noindex?: boolean;
}

const siteUrl =
  Astro.site?.toString().replace(/\/$/, "") || "https://www.arielautosymas.com";
const currentPath = Astro.url.pathname;
const canonical = new URL(currentPath, siteUrl).toString();

const {
  title = "Ariel Autos y Más | Mechanic Services in Miami-Dade",
  description = "Brakes, tires, oil changes, alignments, roadside assistance, and general mechanic services in Miami-Dade County.",
  image = "/images/og/ariel-autos-og.jpg",
  noindex = false,
} = Astro.props;

const pageTitle = title.includes("Ariel Autos y Más")
  ? title
  : `${title} | Ariel Autos y Más`;

const socialImage = new URL(image, siteUrl).toString();

const structuredData = {
  "@context": "https://schema.org",
  "@type": "AutoRepair",
  name: "Ariel Autos y Más",
  url: canonical,
  image: socialImage,
  description,
  areaServed: {
    "@type": "AdministrativeArea",
    name: "Miami-Dade County",
  },
  serviceType: [
    "Brake Services",
    "Tire Services",
    "Oil Changes",
    "Alignments",
    "Roadside Assistance",
    "General Mechanic Services",
  ],
};
---

<!doctype html>
<html lang="en" data-lang="en" class="light">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <meta
      name="robots"
      content={noindex ? "noindex, nofollow" : "index, follow"}
    />
    <meta name="theme-color" content="#f8f4ee" />

    <link rel="canonical" href={canonical} />

    <!-- Language -->
    <link rel="alternate" hrefLang="en" href={canonical} />
    <link rel="alternate" hrefLang="x-default" href={canonical} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="Ariel Autos y Más" />
    <meta property="og:image" content={socialImage} />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImage} />

    <!-- Structured data -->
    <script
      type="application/ld+json"
      set:html={JSON.stringify(structuredData)}
    />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=Outfit:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />

    <script is:inline>
      (() => {
        const themeKey = "ariel-theme";
        const langKey = "ariel-lang";
        const root = document.documentElement;
        const metaTheme = document.querySelector('meta[name="theme-color"]');

        const applyTheme = (theme) => {
          root.classList.remove("light", "dark");
          root.classList.add(theme);
          root.dataset.theme = theme;

          if (metaTheme) {
            metaTheme.setAttribute(
              "content",
              theme === "dark" ? "#0d0b0b" : "#f8f4ee",
            );
          }
        };

        const applyLang = (lang) => {
          root.setAttribute("data-lang", lang);
          root.setAttribute("lang", lang === "es" ? "es" : "en");
        };

        try {
          const storedTheme = localStorage.getItem(themeKey);
          const storedLang = localStorage.getItem(langKey);

          const initialTheme = storedTheme || "light";
          const initialLang = storedLang || "en";

          applyTheme(initialTheme);
          applyLang(initialLang);

          window.__setPreferredTheme = (theme) => {
            localStorage.setItem(themeKey, theme);
            applyTheme(theme);
          };

          window.__getPreferredTheme = () => root.dataset.theme || initialTheme;

          window.__setPreferredLang = (lang) => {
            localStorage.setItem(langKey, lang);
            applyLang(lang);
          };

          window.__getPreferredLang = () => root.dataset.lang || initialLang;
        } catch {
          applyTheme("light");
          applyLang("en");
        }
      })();
    </script>
  </head>

  <body class="antialiased transition-colors duration-300">
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:fixed focus:left-4 focus:top-4 focus:z-[100] focus:rounded-full focus:bg-[rgb(var(--color-surface))] focus:px-4 focus:py-2 focus:text-[rgb(var(--color-text))]"
    >
      Skip to content
    </a>

    <div class="relative min-h-screen overflow-x-clip">
      <div class="pointer-events-none absolute inset-0 -z-10 hero-mist"></div>

      <Header />

      <main id="main-content" class="relative z-10">
        <slot />
      </main>

      <Footer />
    </div>
  </body>
</html>
