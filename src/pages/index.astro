---
import MainLayout from "../layouts/MainLayout.astro";

const services = [
  {
    icon: "🛑",
    enTitle: "Brake Services",
    esTitle: "Servicios de Frenos",
    image: '/images/brakes.webp',
    enText:
      "Brake inspections, maintenance, and replacements to keep your vehicle safer on the road.",
    esText:
      "Inspecciones, mantenimiento y reemplazo de frenos para mantener tu vehículo más seguro en la carretera.",
  },
  {
    icon: "🛞",
    image: '/images/tires.webp',
    enTitle: "Tires",
    esTitle: "Llantas",
    enText:
      "Support with tire checks, replacements, and common tire-related issues.",
    esText:
      "Apoyo con revisión, reemplazo y problemas comunes relacionados con las llantas.",
  },
  {
    icon: "🛢️",
    image: '/images/oil-change.webp',
    enTitle: "Oil Changes",
    esTitle: "Cambios de Aceite",
    enText:
      "Routine oil changes to help your engine perform better and last longer.",
    esText:
      "Cambios de aceite de rutina para ayudar a que el motor rinda mejor y dure más.",
  },
  {
    icon: "📐",
    image: '/images/alignment.webp',
    enTitle: "Alignments",
    esTitle: "Alineación",
    enText:
      "Alignment support to improve vehicle handling and reduce uneven tire wear.",
    esText:
      "Soporte de alineación para mejorar el manejo del vehículo y reducir el desgaste irregular de las llantas.",
  },
  {
    icon: "🔧",
    image: '/images/mechanic.webp',
    enTitle: "General Mechanic Work",
    esTitle: "Mecánica General",
    enText: "Reliable help with many common car repairs and maintenance needs.",
    esText:
      "Ayuda confiable con muchas reparaciones y mantenimientos comunes del auto.",
  },
  {
    icon: "🚐",
    image: '/images/roadside.webp',
    enTitle: "Basic Roadside Assistance",
    esTitle: "Asistencia Básica en Carretera",
    enText:
      "Local roadside support across Miami-Dade for common non-emergency vehicle issues.",
    esText:
      "Soporte local en carretera en Miami-Dade para problemas comunes del vehículo que no sean emergencias.",
  },
];
---

<MainLayout>
  <section class="container-shell pt-10 sm:pt-14 lg:pt-20">
    <div class="grid gap-10 lg:grid-cols-[1.08fr_0.92fr] lg:items-end">
      <div class="reveal">
        <p class="section-label">
          <span data-lang-inline="en">Reliable Auto Repair in Miami-Dade</span>
          <span data-lang-inline="es"
            >Reparación Automotriz Confiable en Miami-Dade</span
          >
        </p>

        <h1
          class="mt-5 max-w-4xl text-5xl font-extrabold leading-[0.95] sm:text-6xl lg:text-[5.25rem]"
        >
          <span data-lang-block="en">
            Auto service that feels dependable before the call even starts.
          </span>
          <span data-lang-block="es">
            Servicios automotrices al alcance de una llamada.
          </span>
        </h1>

        <p
          class="mt-6 max-w-2xl text-base leading-8 text-[rgb(var(--color-text-secondary))] sm:text-lg"
        >
          <span data-lang-block="en">
            Ariel Autos y Más provides practical mechanic support across
            Miami-Dade County with honest service, everyday repair solutions,
            and local help when drivers need it most.
          </span>
          <span data-lang-block="es">
            Ariel Autos y Más ofrece soporte mecánico práctico en Miami-Dade
            County con servicio honesto, soluciones para reparaciones del día a
            día y ayuda local cuando los conductores más la necesitan.
          </span>
        </p>

        <div class="mt-8 flex flex-col gap-3 sm:flex-row">
          <a href="tel:+13059673849" class="button-primary">
            <span data-lang-inline="en">Call Now</span>
            <span data-lang-inline="es">Llama Ahora</span>
          </a>

          <a href="#contact" class="button-secondary">
            <span data-lang-inline="en">Request Service</span>
            <span data-lang-inline="es">Solicitar Servicio</span>
          </a>
        </div>

        <div class="mt-10 grid gap-6 sm:grid-cols-3">
          <div class="editorial-stat">
            <p
              class="text-2xl font-extrabold tracking-[-0.03em] text-[rgb(var(--color-text))]"
            >
              <span data-lang-inline="en">Local</span>
              <span data-lang-inline="es">Local</span>
            </p>
            <p
              class="mt-2 text-sm leading-7 text-[rgb(var(--color-text-secondary))]"
            >
              <span data-lang-block="en"
                >Fast support for everyday vehicle needs in Miami-Dade.</span
              >
              <span data-lang-block="es"
                >Soporte rápido para necesidades diarias del vehículo en
                Miami-Dade.</span
              >
            </p>
          </div>

          <div class="editorial-stat">
            <p
              class="text-2xl font-extrabold tracking-[-0.03em] text-[rgb(var(--color-text))]"
            >
              <span data-lang-inline="en">Trusted</span>
              <span data-lang-inline="es">Confiable</span>
            </p>
            <p
              class="mt-2 text-sm leading-7 text-[rgb(var(--color-text-secondary))]"
            >
              <span data-lang-block="en"
                >Service-first attention with practical solutions.</span
              >
              <span data-lang-block="es"
                >Atención orientada al servicio con soluciones prácticas.</span
              >
            </p>
          </div>

          <div class="editorial-stat">
            <p
              class="text-2xl font-extrabold tracking-[-0.03em] text-[rgb(var(--color-text))]"
            >
              Miami-Dade
            </p>
            <p
              class="mt-2 text-sm leading-7 text-[rgb(var(--color-text-secondary))]"
            >
              <span data-lang-block="en"
                >Coverage built around local drivers and real needs.</span
              >
              <span data-lang-block="es"
                >Cobertura pensada para conductores locales y necesidades
                reales.</span
              >
            </p>
          </div>
        </div>
      </div>

      <div class="reveal">
        <div class="relative overflow-hidden rounded-[2rem]">
          <img
            src="/images/hero-image.webp"
            alt="Ariel Autos y Más service vehicle"
            class="animate-float-soft h-[420px] w-full rounded-[2rem] object-cover sm:h-[520px] lg:h-[700px]"
          />

          <div
            class="absolute inset-0 rounded-[2rem] bg-gradient-to-t from-[rgba(27,15,13,0.34)] via-transparent to-transparent"
          >
          </div>

          <div
            class="absolute bottom-5 left-5 max-w-[15rem] rounded-[1.5rem] bg-white/82 px-4 py-4 backdrop-blur dark:bg-[rgb(var(--color-surface))]/78"
          >
            <p
              class="text-[0.72rem] font-extrabold uppercase tracking-[0.18em] text-[rgb(var(--color-brand-red))]"
            >
              <span data-lang-inline="en">Need Help?</span>
              <span data-lang-inline="es">¿Necesitas Ayuda?</span>
            </p>
            <p
              class="mt-2 text-xl font-extrabold tracking-[-0.03em] text-[rgb(var(--color-text))]"
            >
              +1 (305) 967-3849
            </p>
            <p
              class="mt-2 text-sm leading-6 text-[rgb(var(--color-text-secondary))]"
            >
              <span data-lang-block="en"
                >Call now for mechanic support and basic roadside assistance.</span
              >
              <span data-lang-block="es"
                >Llama ahora para soporte mecánico y asistencia básica en
                carretera.</span
              >
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section id="services" class="container-shell py-20 sm:py-24">
    <div class="mx-auto max-w-3xl text-center reveal">
      <p class="section-label mx-auto">
        <span data-lang-inline="en">Services</span>
        <span data-lang-inline="es">Servicios</span>
      </p>

      <h2 class="mt-5 text-3xl font-extrabold sm:text-4xl lg:text-5xl">
        <span data-lang-block="en">
          Mechanic services designed for real everyday vehicle needs.
        </span>
        <span data-lang-block="es">
          Servicios mecánicos diseñados para las necesidades reales del día a
          día.
        </span>
      </h2>

      <p
        class="mt-4 text-base leading-8 text-[rgb(var(--color-text-secondary))]"
      >
        <span data-lang-block="en">
          A cleaner, more premium presentation of what you offer, with cards
          that feel modern and easy to scan.
        </span>
        <span data-lang-block="es">
          Una presentación más limpia y premium de lo que ofreces, con tarjetas
          modernas y fáciles de escanear.
        </span>
      </p>
    </div>

    <div class="mt-12 grid gap-6 md:grid-cols-2 xl:grid-cols-3">
      {
        services.map((service) => (
          <article class="service-card reveal relative overflow-hidden">

            <h3 class="relative z-10 mt-5 text-2xl font-extrabold tracking-[-0.03em] text-[rgb(var(--color-text))]">
              <span data-lang-inline="en">{service.enTitle}</span>
              <span data-lang-inline="es">{service.esTitle}</span>
            </h3>

            <p class="relative z-10 mt-3 max-w-[85%] text-sm leading-7 text-[rgb(var(--color-text-secondary))]">
              <span data-lang-block="en">{service.enText}</span>
              <span data-lang-block="es">{service.esText}</span>
            </p>

            <div class="relative z-10 mt-6 flex items-center gap-2 text-sm font-bold text-[rgb(var(--color-brand-red))]">
              <span data-lang-inline="en">Learn more</span>
              <span data-lang-inline="es">Conocer más</span>
              <span aria-hidden="true">→</span>
            </div>

            <img
              src={service.image}
              alt=""
              aria-hidden="true"
              class="pointer-events-none absolute bottom-3 right-3 z-0 h-24 w-24 object-contain opacity-90 service-float"
            />
          </article>
        ))
      }
    </div>
  </section>

  <section id="about" class="container-shell pt-20 sm:pt-24 lg:pt-28">
    <div class="grid gap-10 lg:grid-cols-[0.95fr_1.05fr] lg:items-center">
      <div class="reveal order-2 lg:order-1">
        <img
          src="/images/ariel-oil-change.webp"
          alt="Mechanic working placeholder"
          class="h-[360px] w-full rounded-[2rem] object-cover sm:h-[460px] lg:h-[620px]"
        />
      </div>

      <div class="reveal order-1 lg:order-2">
        <p class="section-label">
          <span data-lang-inline="en">Why choose us</span>
          <span data-lang-inline="es">Por qué elegirnos</span>
        </p>

        <h2
          class="mt-5 max-w-2xl text-3xl font-extrabold sm:text-4xl lg:text-[3.4rem]"
        >
          <span data-lang-block="en">
            Built around trust, speed, and practical local service.
          </span>
          <span data-lang-block="es">
            Construido alrededor de confianza, rapidez y servicio local
            práctico.
          </span>
        </h2>

        <p
          class="mt-5 max-w-2xl text-base leading-8 text-[rgb(var(--color-text-secondary))]"
        >
          <span data-lang-block="en">
            At Ariel Autos y Más, we believe great service starts with honesty,
            experience, and treating every customer like family. We’re proud to
            help our community with reliable automotive care, clear
            communication, and the kind of attention that makes people feel
            confident every time they call us.
          </span>
          <span data-lang-block="es">
            En Ariel Autos y Más, creemos que un gran servicio comienza con la
            honestidad, la experiencia y el trato a cada cliente como si fuera
            parte de la familia. Nos enorgullece ayudar a nuestra comunidad con
            un servicio automotriz confiable, una comunicación clara y una
            atención que hace que las personas se sientan seguras cada vez que
            nos llaman.
          </span>
        </p>

        <div class="mt-8 grid gap-6 sm:grid-cols-2">
          <div
            class="px-5 py-4 rounded-[1.5rem] bg-[rgb(var(--color-surface-soft))] dark:bg-[rgb(var(--color-surface))]/78"
          >
            <p class="text-lg font-extrabold text-[rgb(var(--color-text))]">
              <span data-lang-inline="en">Fast response</span>
              <span data-lang-inline="es">Respuesta rápida</span>
            </p>
            <p
              class="mt-2 text-sm leading-7 text-[rgb(var(--color-text-secondary))]"
            >
              <span data-lang-block="en"
                >We work to provide quick assistance, clear updates, and timely
                service so you can get back on the road with less stress.</span
              >
              <span data-lang-block="es"
                >Trabajamos para brindar asistencia rápida, actualizaciones
                claras y un servicio a tiempo para que puedas volver a la
                carretera con menos estrés.</span
              >
            </p>
          </div>

          <div
            class="px-5 py-4 rounded-[1.5rem] bg-[rgb(var(--color-surface-soft))] dark:bg-[rgb(var(--color-surface))]/78"
          >
            <p class="text-lg font-extrabold text-[rgb(var(--color-text))]">
              <span data-lang-inline="en">Reliable workmanship</span>
              <span data-lang-inline="es">Trabajo confiable</span>
            </p>
            <p
              class="mt-2 text-sm leading-7 text-[rgb(var(--color-text-secondary))]"
            >
              <span data-lang-block="en"
                >Our goal is to deliver dependable automotive service with
                careful attention to detail, honest recommendations, and results
                you can trust.</span
              >
              <span data-lang-block="es"
                >Nuestro objetivo es ofrecer un servicio automotriz confiable,
                con atención al detalle, recomendaciones honestas y resultados
                en los que puedas confiar.</span
              >
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section id="coverage" class="container-shell pt-20 sm:pt-24 lg:pt-28">
    <div class="reveal">
      <p class="section-label">
        <span data-lang-inline="en">Coverage Area</span>
        <span data-lang-inline="es">Área de Cobertura</span>
      </p>

      <div class="mt-4 grid gap-8 lg:grid-cols-1 lg:items-end">
        <h2 class="text-3xl font-extrabold sm:text-4xl lg:text-[3.25rem]">
          <span data-lang-block="en"
            >Serving drivers across Miami-Dade County.</span
          >
          <span data-lang-block="es"
            >Sirviendo a conductores en todo Miami-Dade County.</span
          >
        </h2>
      </div>
    </div>

    <div class="mt-10 reveal overflow-hidden rounded-[2rem] shadow-soft">
      <div
        class="flex items-center justify-center bg-[rgb(var(--color-surface-soft))] px-6 py-10 text-center"
      >
        <iframe
          src="https://www.google.com/maps?q=Miami-Dade%20County,%20Florida&output=embed"
          width="100%"
          height="450"
          style="border-radius: 1.5rem; border:0;"
          allowfullscreen=""
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"></iframe>
      </div>
    </div>
  </section>

  <section id="contact" class="container-shell pt-20 sm:pt-24 lg:pt-28 pb-10">
    <div class="grid gap-10 lg:grid-cols-[0.85fr_1.15fr] lg:items-start">
      <div class="reveal">
        <p class="section-label">
          <span data-lang-inline="en">Contact</span>
          <span data-lang-inline="es">Contacto</span>
        </p>

        <h2
          class="mt-5 max-w-2xl text-3xl font-extrabold sm:text-4xl lg:text-[3.3rem]"
        >
          <span data-lang-block="en">
            Request service, ask a question, or start the conversation.
          </span>
          <span data-lang-block="es">
            Solicita servicio, haz una pregunta o empieza la conversación.
          </span>
        </h2>

        <p
          class="mt-5 max-w-xl text-base leading-8 text-[rgb(var(--color-text-secondary))]"
        >
          <span data-lang-block="en">
            Whether you need maintenance, repairs, or more information about our
            services, our team is here to help with clear communication and
            dependable support.
          </span>
          <span data-lang-block="es">
            Ya sea que necesites mantenimiento, reparaciones o más información
            sobre nuestros servicios, nuestro equipo está aquí para ayudarte con
            una comunicación clara y un apoyo confiable.
          </span>
        </p>
      </div>

      <div class="reveal">
        <form
          name="contact"
          method="POST"
          data-netlify="true"
          netlify-honeypot="bot-field"
          action="/thank-you"
          class="space-y-5"
        >
          <input type="hidden" name="form-name" value="contact" />
          <p class="hidden">
            <label>
              Don’t fill this out if you’re human:
              <input name="bot-field" />
            </label>
          </p>

          <div class="grid gap-5 sm:grid-cols-2">
            <div>
              <label
                for="name"
                class="mb-2 block text-sm font-extrabold text-[rgb(var(--color-text))]"
              >
                <span data-lang-inline="en">Name</span>
                <span data-lang-inline="es">Nombre</span>
              </label>
              <input
                id="name"
                name="name"
                type="text"
                required
                class="contact-input"
                placeholder="Your name"
              />
            </div>

            <div>
              <label
                for="phone"
                class="mb-2 block text-sm font-extrabold text-[rgb(var(--color-text))]"
              >
                <span data-lang-inline="en">Phone</span>
                <span data-lang-inline="es">Teléfono</span>
              </label>
              <input
                id="phone"
                name="phone"
                type="tel"
                class="contact-input"
                placeholder="+1 (305) 000-0000"
              />
            </div>
          </div>

          <div class="grid gap-5 sm:grid-cols-2">
            <div>
              <label
                for="email"
                class="mb-2 block text-sm font-extrabold text-[rgb(var(--color-text))]"
              >
                Email
              </label>
              <input
                id="email"
                name="email"
                type="email"
                required
                class="contact-input"
                placeholder="you@example.com"
              />
            </div>

            <div>
              <label
                for="service"
                class="mb-2 block text-sm font-extrabold text-[rgb(var(--color-text))]"
              >
                <span data-lang-inline="en">Service Needed</span>
                <span data-lang-inline="es">Servicio Necesario</span>
              </label>
              <select id="service" name="service" class="contact-input">
                <option value=""> Select a service </option>
                <option value="Brake Services">Brake Services</option>
                <option value="Tires">Tires</option>
                <option value="Oil Changes">Oil Changes</option>
                <option value="Alignments">Alignments</option>
                <option value="General Mechanic Work"
                  >General Mechanic Work</option
                >
                <option value="Roadside Assistance">Roadside Assistance</option>
              </select>
            </div>
          </div>

          <div>
            <label
              for="message"
              class="mb-2 block text-sm font-extrabold text-[rgb(var(--color-text))]"
            >
              <span data-lang-inline="en">Message</span>
              <span data-lang-inline="es">Mensaje</span>
            </label>
            <textarea
              id="message"
              name="message"
              rows="6"
              required
              class="contact-input resize-none"
              placeholder="Tell us how we can help..."></textarea>
          </div>

          <div class="flex flex-col gap-3 sm:flex-row sm:items-center">
            <button type="submit" class="button-primary">
              <span data-lang-inline="en">Send Request</span>
              <span data-lang-inline="es">Enviar Solicitud</span>
            </button>

            <a href="tel:+13059673849" class="button-secondary">
              <span data-lang-inline="en">Call Instead</span>
              <span data-lang-inline="es">Llamar Mejor</span>
            </a>
          </div>
        </form>
      </div>
    </div>
  </section>

  <script is:inline>
    (() => {
      const revealItems = document.querySelectorAll(".reveal");

      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add("is-visible");
            }
          });
        },
        { threshold: 0.14 },
      );

      revealItems.forEach((item) => observer.observe(item));
    })();
  </script>
</MainLayout>
