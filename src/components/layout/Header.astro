---
const navLinks = [
  { href: "#services", en: "Services", es: "Servicios" },
  { href: "#about", en: "About", es: "Nosotros" },
  { href: "#coverage", en: "Coverage", es: "Cobertura" },
  { href: "#contact", en: "Contact", es: "Contacto" },
];
---

<header class="sticky top-0 z-50 px-3 pt-3 sm:px-5">
  <div
    class="mx-auto flex w-full max-w-7xl items-center justify-between gap-4 rounded-[1.75rem] border border-black/6 glass-surface px-4 py-3 shadow-[0_16px_40px_rgba(15,23,42,0.08)] backdrop-blur-xl dark:border-white/10 sm:px-5 lg:px-6"
  >
    <a
      href="/"
      class="group inline-flex shrink-0 items-center gap-3"
      aria-label="Ariel Autos y Más home"
    >
      <span
        class="relative flex h-12 w-12 items-center justify-center overflow-hidden rounded-2xl border border-black/6 bg-white/80 shadow-[0_10px_24px_rgba(0,0,0,0.06)] dark:border-white/10 dark:bg-white/5"
      >
        <img
          src="/images/ariel-autos-logo.webp"
          alt="Ariel Autos y Más logo"
          class="h-full w-full object-contain"
          loading="eager"
        />
      </span>

      <span class="hidden flex-col leading-none sm:flex">
        <span
          class="text-base font-extrabold tracking-[-0.03em] text-[rgb(var(--color-text))]"
        >
          Ariel Autos y Más
        </span>
        <span
          class="mt-1 text-[0.68rem] font-extrabold uppercase tracking-[0.22em] text-[rgb(var(--color-text-secondary))]"
        >
          <span data-lang-inline="en">Miami-Dade Auto Services</span>
          <span data-lang-inline="es">Servicios Automotrices Miami-Dade</span>
        </span>
      </span>
    </a>

    <nav
      class="hidden items-center gap-1 rounded-full border border-black/8 bg-white/70 p-1.5 shadow-[0_12px_30px_rgba(15,23,42,0.06)] dark:border-white/10 dark:bg-white/5 lg:flex"
    >
      {
        navLinks.map((link) => (
          <a
            href={link.href}
            class="rounded-full px-4 py-2.5 text-sm font-bold text-[rgb(var(--color-text-secondary))] transition-all duration-200 hover:bg-[rgb(var(--color-surface-soft))] hover:text-[rgb(var(--color-text))] dark:hover:bg-white/10 dark:hover:text-white"
          >
            <span data-lang-inline="en">{link.en}</span>
            <span data-lang-inline="es">{link.es}</span>
          </a>
        ))
      }
    </nav>

    <div class="flex items-center gap-2 sm:gap-3">
      <div
        class="hidden items-center rounded-full border border-black/8 bg-white/70 p-1 shadow-[0_10px_24px_rgba(15,23,42,0.06)] dark:border-white/10 dark:bg-white/5 sm:flex"
      >
        <button
          type="button"
          data-lang-switch="en"
          class="rounded-full px-3 py-2 text-[0.72rem] font-extrabold tracking-[0.16em] text-[rgb(var(--color-text))] hover:bg-[rgb(var(--color-surface-soft))] dark:hover:bg-white/10"
        >
          EN
        </button>
        <button
          type="button"
          data-lang-switch="es"
          class="rounded-full px-3 py-2 text-[0.72rem] font-extrabold tracking-[0.16em] text-[rgb(var(--color-text))] hover:bg-[rgb(var(--color-surface-soft))] dark:hover:bg-white/10"
        >
          ES
        </button>
      </div>

      <button
        type="button"
        class="group relative inline-flex h-11 w-11 items-center justify-center rounded-full border border-black/8 bg-white/75 text-[rgb(var(--color-text))] shadow-[0_10px_24px_rgba(15,23,42,0.06)] hover:-translate-y-0.5 hover:bg-[rgb(var(--color-surface-soft))] dark:border-white/10 dark:bg-white/5 dark:text-white dark:hover:bg-white/10"
        aria-label="Toggle dark mode"
        data-theme-toggle
      >
        <span class="sr-only">Toggle dark mode</span>

        <svg
          data-theme-icon="sun"
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.8"
          class="h-5 w-5 scale-100 opacity-100 transition-all duration-300 dark:scale-0 dark:opacity-0"
        >
          <circle cx="12" cy="12" r="4"></circle>
          <path
            d="M12 2v2.5M12 19.5V22M4.93 4.93l1.77 1.77M17.3 17.3l1.77 1.77M2 12h2.5M19.5 12H22M4.93 19.07l1.77-1.77M17.3 6.7l1.77-1.77"
          ></path>
        </svg>

        <svg
          data-theme-icon="moon"
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.8"
          class="absolute h-5 w-5 scale-0 opacity-0 transition-all duration-300 dark:scale-100 dark:opacity-100"
        >
          <path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8Z"></path>
        </svg>
      </button>

      <a
        href="tel:+13059673849"
        class="hidden items-center justify-center rounded-full brand-gradient px-5 py-3 text-sm font-extrabold text-white shadow-brand transition-transform duration-200 hover:-translate-y-0.5 lg:inline-flex"
      >
        <span data-lang-inline="en">Call Now</span>
        <span data-lang-inline="es">Llama Ya</span>
      </a>

      <button
        type="button"
        class="inline-flex h-11 w-11 items-center justify-center rounded-full border border-black/8 bg-white/75 text-[rgb(var(--color-text))] shadow-[0_10px_24px_rgba(15,23,42,0.06)] hover:bg-[rgb(var(--color-surface-soft))] dark:border-white/10 dark:bg-white/5 dark:text-white dark:hover:bg-white/10 lg:hidden"
        aria-label="Open menu"
        aria-expanded="false"
        data-mobile-menu-toggle
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          class="h-5 w-5"
        >
          <path d="M4 7h16M4 12h16M4 17h16"></path>
        </svg>
      </button>
    </div>
  </div>

  <div
    class="mx-auto mt-3 hidden w-full max-w-7xl overflow-hidden rounded-[1.75rem] border border-black/8 glass-surface p-4 dark:border-white/10 lg:hidden"
    data-mobile-menu
  >
    <div class="flex flex-col gap-2">
      <div class="mb-2 flex items-center gap-2">
        <button
          type="button"
          data-lang-switch="en"
          class="rounded-full border border-black/10 px-3 py-2 text-[0.72rem] font-extrabold tracking-[0.16em] text-[rgb(var(--color-text))] dark:border-white/10"
        >
          EN
        </button>
        <button
          type="button"
          data-lang-switch="es"
          class="rounded-full border border-black/10 px-3 py-2 text-[0.72rem] font-extrabold tracking-[0.16em] text-[rgb(var(--color-text))] dark:border-white/10"
        >
          ES
        </button>
      </div>

      {
        navLinks.map((link) => (
          <a
            href={link.href}
            class="rounded-2xl px-4 py-3 text-base font-bold text-[rgb(var(--color-text-secondary))] transition-colors hover:bg-[rgb(var(--color-surface-soft))] hover:text-[rgb(var(--color-text))] dark:hover:bg-white/10 dark:hover:text-white"
          >
            <span data-lang-inline="en">{link.en}</span>
            <span data-lang-inline="es">{link.es}</span>
          </a>
        ))
      }

      <a
        href="tel:+13059673849"
        class="mt-2 inline-flex justify-center rounded-full brand-gradient px-5 py-3 text-center text-sm font-extrabold text-white shadow-brand"
      >
        <span data-lang-inline="en">Call Now</span>
        <span data-lang-inline="es">Llama Ya</span>
      </a>
    </div>
  </div>
</header>

<script is:inline>
  (() => {
    const doc = document.documentElement;
    const themeButton = document.querySelector("[data-theme-toggle]");
    const menuButton = document.querySelector("[data-mobile-menu-toggle]");
    const mobileMenu = document.querySelector("[data-mobile-menu]");
    const langButtons = document.querySelectorAll("[data-lang-switch]");

    const getTheme = () => {
      if (doc.classList.contains("dark")) return "dark";
      return "light";
    };

    const syncThemeButton = () => {
      if (!themeButton) return;
      themeButton.setAttribute(
        "aria-label",
        getTheme() === "dark" ? "Switch to light mode" : "Switch to dark mode",
      );
    };

    const closeMenu = () => {
      if (!menuButton || !mobileMenu) return;
      menuButton.setAttribute("aria-expanded", "false");
      mobileMenu.classList.add("hidden");
    };

    const toggleMenu = () => {
      if (!menuButton || !mobileMenu) return;
      const isOpen = menuButton.getAttribute("aria-expanded") === "true";
      menuButton.setAttribute("aria-expanded", String(!isOpen));
      mobileMenu.classList.toggle("hidden", isOpen);
    };

    syncThemeButton();

    themeButton?.addEventListener("click", () => {
      const nextTheme = getTheme() === "dark" ? "light" : "dark";

      if (typeof window.__setPreferredTheme === "function") {
        window.__setPreferredTheme(nextTheme);
      }

      syncThemeButton();
    });

    langButtons.forEach((button) => {
      button.addEventListener("click", () => {
        const lang = button.getAttribute("data-lang-switch");
        if (!lang) return;

        if (typeof window.__setPreferredLang === "function") {
          window.__setPreferredLang(lang);
        }
      });
    });

    menuButton?.addEventListener("click", toggleMenu);

    mobileMenu?.querySelectorAll("a").forEach((link) => {
      link.addEventListener("click", closeMenu);
    });

    window.addEventListener("resize", () => {
      if (window.innerWidth >= 1024) closeMenu();
    });
  })();
</script>
