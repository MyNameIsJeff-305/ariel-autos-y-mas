---
const quickLinks = [
  { href: "#services", en: "Services", es: "Servicios" },
  { href: "#about", en: "About", es: "Nosotros" },
  { href: "#coverage", en: "Coverage", es: "Cobertura" },
  { href: "#contact", en: "Contact", es: "Contacto" },
];

const currentYear = new Date().getFullYear();
---

<footer
  class="relative mt-24 border-t border-black/8 bg-[rgb(var(--color-surface))] dark:border-white/10"
>
  <div class="container-shell py-10 sm:py-12">
    <div class="grid gap-8 lg:grid-cols-[1.15fr_0.85fr_0.9fr]">
      <div>
        <a href="/" class="flex flex-col gap-4">
          <span class="flex h-40 w-40 items-center justify-center overflow-hidden rounded-2xl">
            <img
              src="/images/ariel-autos-logo.webp"
              alt="Ariel Autos y Más logo"
              class="h-full w-full object-contain"
            />
          </span>

          <span class="flex flex-col leading-none">
            <span class="text-lg font-extrabold tracking-[-0.03em] text-[rgb(var(--color-text))]">
              Ariel Autos y Más
            </span>
            <span class="mt-1 text-[0.68rem] font-extrabold uppercase tracking-[0.2em] text-[rgb(var(--color-text-secondary))]">
              <span data-lang-inline="en">Mechanic Services in Miami-Dade</span>
              <span data-lang-inline="es">Servicios Mecánicos en Miami-Dade</span>
            </span>
          </span>
        </a>

        <p class="mt-4 max-w-md text-sm leading-7 text-[rgb(var(--color-text-secondary))]">
          <span data-lang-block="en">
            Reliable mechanic support with practical service, honest attention, and local coverage across Miami-Dade County.
          </span>
          <span data-lang-block="es">
            Soporte mecánico confiable con servicio práctico, atención honesta y cobertura local en Miami-Dade County.
          </span>
        </p>
      </div>

      <div>
        <h3 class="text-base font-extrabold text-[rgb(var(--color-text))]">
          <span data-lang-inline="en">Navigation</span>
          <span data-lang-inline="es">Navegación</span>
        </h3>

        <ul class="mt-4 space-y-3">
          {
            quickLinks.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="text-sm font-semibold text-[rgb(var(--color-text-secondary))] transition-colors hover:text-[rgb(var(--color-text))]"
                >
                  <span data-lang-inline="en">{link.en}</span>
                  <span data-lang-inline="es">{link.es}</span>
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <div>
        <h3 class="text-base font-extrabold text-[rgb(var(--color-text))]">
          <span data-lang-inline="en">Contact</span>
          <span data-lang-inline="es">Contacto</span>
        </h3>

        <ul class="mt-4 space-y-4 text-sm font-semibold text-[rgb(var(--color-text-secondary))]">
          <li>
            <a href="tel:+13059673849" class="transition-colors hover:text-[rgb(var(--color-text))]">
              +1 (305) 967-3849
            </a>
          </li>
          <li>
            <a href="mailto:info@arielautosymas.com" class="transition-colors hover:text-[rgb(var(--color-text))]">
              info@arielautosymas.com
            </a>
          </li>
          <li>Miami-Dade County, Florida</li>
        </ul>
      </div>
    </div>

    <div class="mt-8 editorial-line"></div>

    <div class="mt-5 flex flex-col gap-3 text-sm text-[rgb(var(--color-text-secondary))] sm:flex-row sm:items-center sm:justify-between">
      <p>
        © {currentYear} Ariel Autos y Más.
        <span data-lang-inline="en"> All rights reserved.</span>
        <span data-lang-inline="es"> Todos los derechos reservados.</span>
      </p>

      <p>
        <span data-lang-inline="en">Serving Miami-Dade with trusted auto service.</span>
        <span data-lang-inline="es">Sirviendo a Miami-Dade con servicio automotriz confiable.</span>
      </p>
    </div>
  </div>
</footer>